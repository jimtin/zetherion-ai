{
  "protected_globs": [
    "src/zetherion_ai/api/server.py",
    "src/zetherion_ai/api/routes/**",
    "src/zetherion_ai/cgs_gateway/server.py",
    "src/zetherion_ai/cgs_gateway/routes/**",
    "src/zetherion_ai/memory/qdrant.py",
    "src/zetherion_ai/config.py",
    "src/zetherion_ai/analytics/replay_store.py",
    "src/zetherion_ai/**/models.py",
    "src/zetherion_ai/**/context.py",
    "src/zetherion_ai/**/*storage*.py",
    "src/zetherion_ai/main.py",
    "src/zetherion_ai/skills/server.py",
    "src/zetherion_ai/trust/**",
    "src/zetherion_ai/personal/**",
    "src/zetherion_ai/profile/**",
    "src/zetherion_ai/portfolio/**",
    "src/zetherion_ai/routing/**",
    "src/zetherion_ai/queue/**",
    "src/zetherion_ai/security/trust_policy.py",
    ".github/workflows/**",
    ".ci/pipeline_contract.json",
    "scripts/check-cicd-success.sh",
    "scripts/ci-required-e2e-gate.sh",
    "scripts/ci_required_e2e_gate.py",
    "scripts/ci_e2e_risk_classifier.py",
    "scripts/ci_failure_attribution.py",
    "scripts/require-local-gate-update.sh",
    "scripts/validate-deployment-receipt.py",
    "scripts/check-optional-service-guards.py",
    "scripts/windows/deploy-runner.ps1",
    "scripts/verify-windows-host.ps1"
  ],
  "requirements": {
    "endpoint-doc-bundle": {
      "kind": "check",
      "description": "Run the endpoint documentation bundle check against the exact commit being pushed."
    },
    "mypy-src": {
      "kind": "check",
      "description": "Run strict mypy over src/zetherion_ai against the exact commit being pushed."
    },
    "bandit-src": {
      "kind": "check",
      "description": "Run Bandit over src/ against the exact commit being pushed."
    },
    "unit-full": {
      "kind": "lane",
      "description": "Run the bounded unit-full lane to enforce repo-wide coverage for shared runtime, model, context, and storage changes."
    },
    "qdrant-regression-suite": {
      "kind": "pytest",
      "description": "Run the targeted Qdrant and data-plane regression suite.",
      "pytest_targets": [
        "tests/unit/test_qdrant.py",
        "tests/unit/test_data_plane_isolation.py",
        "tests/test_qdrant.py"
      ]
    },
    "replay-store-regression-suite": {
      "kind": "pytest",
      "description": "Run the targeted replay-store regression suite.",
      "pytest_targets": [
        "tests/unit/test_analytics_replay_store.py"
      ]
    },
    "ci-receipt-regression-suite": {
      "kind": "pytest",
      "description": "Run the targeted receipt, shell, and deployment-receipt regression suite.",
      "pytest_targets": [
        "tests/unit/test_check_cicd_success.py",
        "tests/unit/test_ci_required_e2e_gate.py",
        "tests/unit/test_validate_deployment_receipt.py"
      ]
    },
    "ci-failure-attribution-regression-suite": {
      "kind": "pytest",
      "description": "Run the targeted CI failure-attribution and local-gate-enforcement regression suite.",
      "pytest_targets": [
        "tests/unit/test_ci_failure_attribution.py",
        "tests/unit/test_require_local_gate_update.py"
      ]
    },
    "deploy-preflight-regression-suite": {
      "kind": "pytest",
      "description": "Run the targeted Windows deploy preflight and optional-service regression suite.",
      "pytest_targets": [
        "tests/unit/test_check_optional_service_guards.py",
        "tests/unit/test_validate_deployment_receipt.py"
      ]
    }
  },
  "rules": [
    {
      "id": "python-typecheck",
      "patterns": [
        "src/zetherion_ai/**",
        "updater_sidecar/**"
      ],
      "requirements": [
        "mypy-src",
        "bandit-src"
      ]
    },
    {
      "id": "route-doc-bundle",
      "covers_protected": true,
      "patterns": [
        "src/zetherion_ai/api/server.py",
        "src/zetherion_ai/api/routes/**",
        "src/zetherion_ai/cgs_gateway/server.py",
        "src/zetherion_ai/cgs_gateway/routes/**"
      ],
      "requirements": [
        "endpoint-doc-bundle"
      ]
    },
    {
      "id": "shared-runtime-coverage",
      "covers_protected": true,
      "patterns": [
        "src/zetherion_ai/**/models.py",
        "src/zetherion_ai/**/context.py",
        "src/zetherion_ai/**/*storage*.py",
        "src/zetherion_ai/main.py",
        "src/zetherion_ai/skills/server.py",
        "src/zetherion_ai/trust/**",
        "src/zetherion_ai/personal/**",
        "src/zetherion_ai/profile/**",
        "src/zetherion_ai/portfolio/**",
        "src/zetherion_ai/routing/**",
        "src/zetherion_ai/queue/**",
        "src/zetherion_ai/security/trust_policy.py"
      ],
      "requirements": [
        "unit-full"
      ]
    },
    {
      "id": "qdrant-regression",
      "covers_protected": true,
      "patterns": [
        "src/zetherion_ai/memory/qdrant.py",
        "src/zetherion_ai/config.py"
      ],
      "requirements": [
        "qdrant-regression-suite"
      ]
    },
    {
      "id": "replay-store-regression",
      "covers_protected": true,
      "patterns": [
        "src/zetherion_ai/analytics/replay_store.py"
      ],
      "requirements": [
        "replay-store-regression-suite"
      ]
    },
    {
      "id": "ci-support-regressions",
      "covers_protected": true,
      "patterns": [
        ".github/workflows/**",
        ".ci/pipeline_contract.json",
        "scripts/check-cicd-success.sh",
        "scripts/ci-required-e2e-gate.sh",
        "scripts/ci_required_e2e_gate.py",
        "scripts/ci_e2e_risk_classifier.py",
        "scripts/ci_failure_attribution.py",
        "scripts/require-local-gate-update.sh"
      ],
      "requirements": [
        "ci-receipt-regression-suite",
        "ci-failure-attribution-regression-suite"
      ]
    },
    {
      "id": "deploy-preflight-regressions",
      "covers_protected": true,
      "patterns": [
        "scripts/validate-deployment-receipt.py",
        "scripts/check-optional-service-guards.py",
        "scripts/windows/deploy-runner.ps1",
        "scripts/verify-windows-host.ps1"
      ],
      "requirements": [
        "deploy-preflight-regression-suite",
        "ci-receipt-regression-suite"
      ]
    }
  ]
}
