# Discord Bot Token - Required
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=

# Gemini API Key - Required for Gemini router path
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic API Key - Optional, for Claude as LLM
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API Key - Optional, alternative LLM
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ======================================
# GOOGLE / WORK ROUTER INTEGRATIONS
# ======================================
# Google OAuth credentials (required for Gmail/Calendar/Tasks routing)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Callback endpoint served by the skills service
GOOGLE_REDIRECT_URI=http://localhost:8080/gmail/callback

# Provider-agnostic work router feature flags
WORK_ROUTER_ENABLED=false
PROVIDER_OUTLOOK_ENABLED=false
EMAIL_SECURITY_GATE_ENABLED=true
# Cloud-first extraction when false (Groq -> Gemini -> Claude -> OpenAI -> local)
LOCAL_EXTRACTION_REQUIRED=false

# Discord User IDs allowed to interact (comma-separated)
# Leave empty to allow all users (not recommended for production)
# Example: ALLOWED_USER_IDS=123456789,987654321
# To get your Discord User ID: Enable Developer Mode in Discord settings,
# right-click your username, and select "Copy User ID"
ALLOWED_USER_IDS=

# Dev-agent webhook identity checks (discord bot -> dev watcher ingest)
DEV_AGENT_ENABLED=false
DEV_AGENT_SERVICE_URL=http://zetherion-ai-dev-agent:8787
# One-time bootstrap secret for /v1/bootstrap
DEV_AGENT_BOOTSTRAP_SECRET=
DEV_AGENT_CLEANUP_HOUR=2
DEV_AGENT_CLEANUP_MINUTE=30
DEV_AGENT_APPROVAL_REPROMPT_HOURS=24
DEV_AGENT_DISCORD_CHANNEL_ID=
DEV_AGENT_DISCORD_GUILD_ID=
DEV_AGENT_WEBHOOK_NAME=zetherion-dev-agent
# Optional: lock ingestion to one webhook ID in addition to username
DEV_AGENT_WEBHOOK_ID=
# Retain dev journal events for this many days
DEV_JOURNAL_RETENTION_DAYS=120

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Qdrant Configuration
# For local development with Docker: use "localhost"
# For Docker Compose: use "qdrant" (service name)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ======================================
# MODEL VERSIONS (Updated: 2026-02-05)
# ======================================
# Run 'python scripts/check-model-versions.py' to see latest available models

# Claude Model (for complex tasks)
# Options: claude-sonnet-4-5-20250929 (default), claude-opus-4-5-20251101 (best quality), claude-haiku-4-20250514 (fastest)
# Latest: https://docs.anthropic.com/en/docs/about-claude/models
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# OpenAI Model (alternative to Claude)
# Options: gpt-5.2 (default), gpt-5.2-2026-01-15 (pinned), gpt-4o (fallback)
# Latest: https://platform.openai.com/docs/models
OPENAI_MODEL=gpt-5.2

# Gemini Router Model (for message classification and simple queries)
# Options: gemini-2.5-flash (default, stable), gemini-3-flash-preview (latest preview)
# NOTE: Gemini 2.0 Flash was deprecated and shuts down March 31, 2026
# Latest: https://ai.google.dev/gemini-api/docs/models
ROUTER_MODEL=gemini-2.5-flash

# Gemini Embedding Model
# Options: text-embedding-004 (default)
EMBEDDING_MODEL=text-embedding-004

# ======================================
# ROUTER BACKEND (Updated: 2026-02-05)
# ======================================
# Router Backend: 'gemini' (default), 'groq', or 'ollama'
# - gemini: Uses Google's cloud API
# - groq: Uses Groq's hosted Llama routing path (fastest inbound)
# - ollama: Uses local Ollama container (private, self-hosted)
ROUTER_BACKEND=gemini

# ======================================
# OLLAMA CONFIGURATION (Dual Container Architecture)
# ======================================
# Uses TWO Ollama containers:
# 1. ollama-router: Small, fast model for routing (always loaded)
# 2. ollama: Larger model for generation + embeddings (always loaded)
# This avoids model-swapping delays between routing and generation.

# --- Router Container (ollama-router) ---
# Dedicated container for fast message classification
# For Docker Compose: use "ollama-router" (service name)
# For local development: use "localhost" with port 11435
OLLAMA_ROUTER_HOST=ollama-router
OLLAMA_ROUTER_PORT=11434

# Router model: Small, fast model for classification
# Recommended: llama3.2:3b (default), phi3:mini (alternative)
OLLAMA_ROUTER_MODEL=llama3.2:3b

# --- Generation Container (ollama) ---
# Main container for complex queries and embeddings
# For Docker Compose: use "ollama" (service name)
# For local development: use "localhost" with port 11434
OLLAMA_HOST=ollama
OLLAMA_PORT=11434

# Generation model: Larger, more capable model
# Recommended: llama3.1:8b (default), llama3.1:70b (best quality)
# Browse: https://ollama.com/library
# Run 'python scripts/assess-system.py' for hardware-specific recommendations
OLLAMA_GENERATION_MODEL=llama3.1:8b

# Ollama Docker Memory Allocation (GB)
# Automatically set by assess-system.py based on selected model
# Router container: 1GB (small model)
# Generation container: 8GB (large model + embeddings)
OLLAMA_DOCKER_MEMORY=8

# Ollama API timeout (seconds)
OLLAMA_TIMEOUT=30

# Ollama Embedding Model (for local embeddings)
# Used when EMBEDDINGS_BACKEND=ollama
# Runs on generation container (ollama)
# nomic-embed-text produces 768-dimensional vectors (same as Gemini)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ======================================
# GROQ API (for email classification)
# ======================================
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# Groq Model (for email classification)
# Options: llama-3.3-70b-versatile (default, 85% accuracy), llama-4-maverick-17b-128e (fastest)
# Latest: https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile

# Groq OpenAI-compatible API base URL (override for proxies/testing)
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ======================================
# EMBEDDINGS CONFIGURATION
# ======================================
# Embeddings Backend: 'openai' (default), 'gemini', or 'ollama'
# - openai: Highest-quality cloud embeddings (requires OPENAI_API_KEY)
# - gemini: Google's cloud embeddings (requires GEMINI_API_KEY)
# - ollama: Local embeddings via Ollama generation container
EMBEDDINGS_BACKEND=openai

# OpenAI embedding model (best quality)
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072

# RAG provider/model override allow-lists for document intelligence endpoints
# Allowed providers: groq,openai,claude
RAG_ALLOWED_PROVIDERS=groq,openai,claude
# Optional explicit model allow-list (comma-separated); empty keeps provider defaults only
RAG_ALLOWED_MODELS=

# ======================================
# LOGGING CONFIGURATION
# ======================================
# Enable file-based logging (in addition to console)
LOG_TO_FILE=true

# Log directory (relative or absolute path)
# In Docker: /app/logs (mounted to ./logs on host)
LOG_DIRECTORY=logs

# Log file rotation settings
LOG_FILE_MAX_BYTES=52428800  # 50MB per file
LOG_FILE_BACKUP_COUNT=10      # Keep 10 rotated files (500MB total max)

# ======================================
# ENCRYPTION (Phase 5A) - ENABLED BY DEFAULT
# ======================================
# Enable field-level encryption for sensitive data in Qdrant
# When enabled, message and memory content is encrypted at rest
ENCRYPTION_ENABLED=true

# Master passphrase for encryption key derivation (min 16 characters)
# Generate a strong passphrase: openssl rand -base64 32
# ⚠️  WARNING: Keep this secret! Lost passphrase = unrecoverable data
ENCRYPTION_PASSPHRASE=

# Path to store the encryption salt file (created automatically)
ENCRYPTION_SALT_PATH=data/salt.bin

# ======================================
# QDRANT TLS (Phase 5A) - OPTIONAL
# ======================================
# Enable TLS for Qdrant connection (in-transit encryption)
# Requires running: scripts/generate-qdrant-certs.sh first
QDRANT_USE_TLS=false

# Path to Qdrant TLS certificate (for verification, optional)
# Leave empty to skip verification (acceptable for internal Docker network)
QDRANT_CERT_PATH=

# ======================================
# DISCORD E2E TESTING (OPTIONAL)
# ======================================
# Only needed for running Discord end-to-end integration tests
# These tests send real messages through Discord API

# Test bot token (separate from main DISCORD_TOKEN)
# Create a separate bot in Discord Developer Portal for testing
TEST_DISCORD_BOT_TOKEN=

# Test channel ID where tests will run
# Create a dedicated test server/channel for E2E tests
# Get channel ID: Enable Developer Mode, right-click channel → "Copy Channel ID"
TEST_DISCORD_CHANNEL_ID=

# (Optional) Explicit bot ID to test against
# If not set, tests will auto-detect bot by looking for "zetherion" in bot names
# Get bot ID: Enable Developer Mode, right-click bot → "Copy User ID"
TEST_DISCORD_TARGET_BOT_ID=

# Required Discord E2E provider mode for canonical test-full gate:
# - groq (default): cloud-first path, requires GROQ_API_KEY
# - local: local-model path for explicit local validation runs
DISCORD_E2E_PROVIDER=groq

# Optional override for canonical gate:
# - false (default): keep DISCORD_E2E_PROVIDER as configured (normally groq)
# - true: force local-model Discord E2E mode (sets provider to local)
RUN_DISCORD_E2E_LOCAL_MODEL=false

# Allow messages from other bots (required for Discord E2E tests)
# Set to 'true' to allow the test bot to send messages to the production bot
# ⚠️  WARNING: Keep this 'false' in production to prevent bot-to-bot spam
ALLOW_BOT_MESSAGES=false

# ======================================
# PROFILE SYSTEM (Phase 5C)
# ======================================
# Enable profile extraction from conversations
PROFILE_INFERENCE_ENABLED=true

# Only use Tier 1 (free regex-based) inference
# Set to 'true' to disable Ollama-based profile extraction (saves resources)
PROFILE_TIER1_ONLY=false

# Minimum confidence to auto-apply profile updates (0.0-1.0)
PROFILE_CONFIDENCE_THRESHOLD=0.6

# Profile cache TTL in seconds (default 5 minutes)
PROFILE_CACHE_TTL=300

# Path to SQLite database for profile operational data
PROFILE_DB_PATH=data/profiles.db

# Maximum pending confirmations per user
PROFILE_MAX_PENDING_CONFIRMATIONS=5

# Hours before pending confirmations expire (auto-decline)
PROFILE_CONFIRMATION_EXPIRY_HOURS=72

# ======================================
# EMPLOYMENT PROFILE DEFAULTS (Phase 5C.1)
# ======================================
# Initial communication style settings (0.0-1.0)
DEFAULT_FORMALITY=0.5   # 0=casual, 1=formal
DEFAULT_VERBOSITY=0.5   # 0=terse, 1=detailed
DEFAULT_PROACTIVITY=0.3 # 0=reactive, 1=proactive

# How fast trust builds per positive interaction
TRUST_EVOLUTION_RATE=0.05

# ======================================
# PUBLIC API (Phase 11 - Multi-Tenant)
# ======================================
# JWT secret for signing session tokens (required for public API)
# Generate: openssl rand -base64 32
API_JWT_SECRET=

# Public API bind host and port
API_HOST=0.0.0.0
API_PORT=8443

# ======================================
# CGS GATEWAY (Phase 11.1 - API Provider Layer)
# ======================================
# CGS gateway bind host and port
CGS_GATEWAY_HOST=0.0.0.0
CGS_GATEWAY_PORT=8743

# Optional CORS allow-list for CGS browser clients (comma-separated)
CGS_GATEWAY_ALLOWED_ORIGINS=

# JWT verification settings for CGS app/operator tokens
CGS_AUTH_JWKS_URL=
CGS_AUTH_ISSUER=
CGS_AUTH_AUDIENCE=

# Upstream Zetherion APIs used by the gateway
ZETHERION_PUBLIC_API_BASE_URL=http://zetherion-ai-traefik:8443
ZETHERION_SKILLS_API_BASE_URL=http://zetherion-ai-traefik:8080

# Per-tenant mutation rate limits (requests per minute) for document/admin families
CGS_DOCUMENT_MUTATION_RPM=30
CGS_ADMIN_MUTATION_RPM=20

# Shared secret for Zetherion Skills API calls from CGS gateway
# Falls back to SKILLS_API_SECRET when unset
ZETHERION_SKILLS_API_SECRET=
SKILLS_API_SECRET=

# Next.js /cgs UI BFF auth settings
CGS_SESSION_COOKIE_NAME=cgs_session
CGS_GATEWAY_BASE_URL=http://zetherion-ai-traefik:8443/service/ai/v1

# Post-deploy CGS publish adapter for release blog automation
CGS_BLOG_PUBLISH_URL=
CGS_BLOG_PUBLISH_TOKEN=
GITHUB_PROMOTION_TOKEN=
BLOG_MODEL_PRIMARY=gpt-5.2
BLOG_MODEL_SECONDARY=claude-sonnet-4-6
BLOG_PUBLISH_ENABLED=true

# Release automation (post successful deployed main merge)
RELEASE_AUTO_INCREMENT_ENABLED=true

# ======================================
# APP WATCHER / ANALYTICS
# ======================================
# Raw behavior event retention window (days)
ANALYTICS_EVENT_RETENTION_DAYS=90
# Replay metadata retention window (days)
ANALYTICS_REPLAY_RETENTION_DAYS=14
# Tenant default replay policy (can be overridden per tenant config)
ANALYTICS_REPLAY_ENABLED_DEFAULT=false
ANALYTICS_REPLAY_SAMPLE_RATE_DEFAULT=0.1

# Analytics background job scheduler
ANALYTICS_JOBS_ENABLED=true
ANALYTICS_HOURLY_JOB_INTERVAL_SECONDS=3600
ANALYTICS_DAILY_JOB_INTERVAL_SECONDS=86400

# Replay object storage backend: none | local | s3 (S3-compatible API)
# Legacy REPLAY_STORAGE_* names are still accepted for backward compatibility.
OBJECT_STORAGE_BACKEND=local
OBJECT_STORAGE_LOCAL_PATH=data/replay_chunks
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# Optional signed release marker ingress (in addition to API key auth)
RELEASE_MARKER_SIGNING_SECRET=
RELEASE_MARKER_SIGNATURE_TTL_SECONDS=300

# Trust ladder mode:
# - recommend_only
# - guarded_autopilot
# - full_autonomous
APP_WATCHER_TRUST_MODE=recommend_only
APP_WATCHER_AUTOPILOT_ENABLED=false
APP_WATCHER_GLOBAL_KILL_SWITCH=false

# ======================================
# CLOUDFLARE TUNNEL (Phase 11)
# ======================================
# Cloudflare Tunnel token for exposing the public API without opening ports
# Create at: https://one.dash.cloudflare.com → Zero Trust → Networks → Tunnels
# Configure the tunnel to route traffic to http://zetherion-ai-api:8443
CLOUDFLARE_TUNNEL_TOKEN=

# ======================================
# AUTO-UPDATE (Phase 10A)
# ======================================
# Enable automatic update checking via GitHub Releases API
AUTO_UPDATE_ENABLED=false

# GitHub repo for update checks (owner/repo)
AUTO_UPDATE_REPO=jimtin/zetherion-ai

# Minutes between checks (heartbeat-aligned; default 15)
AUTO_UPDATE_CHECK_INTERVAL_MINUTES=15

# Require owner approval before applying updates (true = manual, false = auto)
UPDATE_REQUIRE_APPROVAL=false

# Pause future auto-rollouts after the first failed rollout
AUTO_UPDATE_PAUSE_ON_FAILURE=true

# ======================================
# UPDATER SIDECAR
# ======================================
# Internal updater sidecar URL (skills service -> updater sidecar)
UPDATER_SERVICE_URL=http://zetherion-ai-updater:9090

# Shared updater secret (leave empty to read from UPDATER_SECRET_PATH file)
UPDATER_SECRET=

# Shared secret path used by skills and updater sidecar
UPDATER_SECRET_PATH=/app/data/.updater-secret

# Updater state file (active color, pause state, last good tag)
UPDATER_STATE_PATH=/app/data/updater-state.json

# Traefik dynamic route file updated by updater sidecar during blue/green flips
UPDATER_TRAEFIK_DYNAMIC_PATH=/project/config/traefik/dynamic/updater-routes.yml

# Enforce signed-release verification before update apply (Cosign keyless + Rekor)
UPDATER_VERIFY_SIGNATURES=true
# Example identity:
# https://github.com/owner/repo/.github/workflows/release.yml@refs/tags/*
UPDATER_VERIFY_IDENTITY=
UPDATER_VERIFY_OIDC_ISSUER=https://token.actions.githubusercontent.com
UPDATER_VERIFY_REKOR_URL=https://rekor.sigstore.dev
UPDATER_RELEASE_MANIFEST_ASSET=release-manifest.json
UPDATER_RELEASE_SIGNATURE_ASSET=release-manifest.sig
UPDATER_RELEASE_CERTIFICATE_ASSET=release-manifest.pem

# Docker socket path (default works for Linux/macOS)
# Windows: set to //./pipe/docker_engine
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Log file prefix (set per container: bot, skills, api)
LOG_FILE_PREFIX=zetherion_ai
