#!/usr/bin/env bash
# Canonical pre-push hook for Zetherion AI.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"

cd "$REPO_DIR"

remote_name="${1:-}"
remote_url="${2:-}"

# Capture ref updates from stdin.
updates=()
while IFS= read -r line; do
    updates+=("$line")
done

# Skip full validation when push only deletes remote refs.
# Pre-push lines are:
#   <local-ref> <local-oid> <remote-ref> <remote-oid>
# Deletions have local-ref "(delete)" and/or local-oid all zeros.
if [ "${#updates[@]}" -gt 0 ]; then
    empty_tree_oid="$(git hash-object -t tree /dev/null)"
    delete_only=true
    for update in "${updates[@]}"; do
        # shellcheck disable=SC2086
        set -- $update
        local_ref="${1:-}"
        local_oid="${2:-}"
        remote_oid="${4:-}"
        if [ "$local_ref" != "(delete)" ] && [ "$local_oid" != "0000000000000000000000000000000000000000" ]; then
            delete_only=false
            base_oid="$remote_oid"
            if [ -z "$base_oid" ] || [ "$base_oid" = "0000000000000000000000000000000000000000" ]; then
                base_oid="$empty_tree_oid"
            fi
            if ! scripts/check-zetherion-boundary.sh "$base_oid" "$local_oid"; then
                echo "[pre-push] Boundary enforcement failed for $local_ref."
                exit 1
            fi
        fi
    done
    if [ "$delete_only" = true ]; then
        echo "[pre-push] Delete-only push to ${remote_name:-<unknown>} (${remote_url:-<unknown>}); skipping full test gate."
        exit 0
    fi
fi

exec ./scripts/test-full.sh "$remote_name" "$remote_url"
